import yfinance as yf
import pandas as pd
import matplotlib.pyplot as plt

pares_bmv = [
    'ASURB.MX', 'GAPB.MX',
    'GFNORTEO.MX', 'GFINBURO.MX',
    'CEMEXCPO.MX', 'GCC.MX',
    'FEMSAUBD.MX', 'AC.MX',
    'AMXB.MX', 'TLEVISACPO.MX',
    'BIMBOA.MX', 'GRUMAB.MX',
    'WALMEX.MX', 'CHDRAUIB.MX',
    'GMEXICOB.MX', 'PE&OLES.MX',
    'ALFA.MX', 'CUERVO.MX',
    'BBAJIOO.MX', 'KOFUBL.MX'
]

fecha_inicio = '2020-01-01'
fecha_fin = '2024-12-31'

print("Descargando datos...")

# Usamos group_by='column' para asegurar que extraemos bien los precios
datos_raw = yf.download(pares_bmv, start=fecha_inicio, end=fecha_fin, auto_adjust=True)

# 3. Extraer solo los precios de cierre (Close)
# En versiones nuevas de yfinance con auto_adjust, 'Adj Close' se convierte en 'Close'
if 'Close' in datos_raw.columns:
    datos = datos_raw['Close']
else:
    datos = datos_raw['Adj Close']

datos = datos.ffill().dropna()

# 5. Verificación de seguridad
if datos.empty:
    print("Error: El DataFrame sigue vacío. Revisa tu conexión o los tickers.")
else:
    print("\nÉxito. Datos descargados para los siguientes activos:")
    print(datos.columns.tolist())

    # Guardar
    nombre_archivo = 'articulodatos.csv' # RECUERDA CAMBIAR ESTO A TU CUENTA
    datos.to_csv(nombre_archivo)

    # Graficar solo si los activos existen en la descarga
    par_ejemplo = ['ASURB.MX', 'GAPB.MX']
    if all(x in datos.columns for x in par_ejemplo):
        datos[par_ejemplo].plot(figsize=(10, 5))
        plt.title('Evolución de Precios: ASUR vs GAP')
        plt.show()
